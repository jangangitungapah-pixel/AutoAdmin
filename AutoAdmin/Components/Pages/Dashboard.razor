@page "/dashboard"
@layout AppLayout
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject AutoAdminDbContext Db
@inject NavigationManager Navigation

<PageTitle>Dashboard - AutoAdmin</PageTitle>

<PageHeader
    Kicker="Command center"
    Title="@BusinessName"
    Description="Pantau invoice, pipeline, task, dan follow-up harian dalam satu layar operasional.">
    <Actions>
        <a class="aa-btn aa-btn-secondary" href="/clients">Manage clients</a>
        <a class="aa-btn aa-btn-primary" href="/invoices/create">New invoice</a>
    </Actions>
</PageHeader>

<section class="aa-dashboard-grid">
    <StatCard Label="Paid Revenue" Value="@Money(Stats.PaidRevenue)" Hint="Invoice yang sudah lunas" />
    <StatCard Label="Receivables" Value="@Money(Stats.Receivables)" Hint="Belum dibayar" />
    <StatCard Label="Pipeline" Value="@Money(Stats.PipelineValue)" Hint="@($"{Stats.ActiveClients} client aktif")" />
    <StatCard Label="Open Tasks" Value="@Stats.OpenTasks.ToString("N0")" Hint="Perlu follow-up" />
</section>

<section class="aa-content-grid">
    <article class="aa-panel aa-panel-large">
        <div class="aa-panel-header aa-panel-header-split">
            <div>
                <span>Today's focus</span>
                <h2>@FocusTitle</h2>
            </div>
            <StatusBadge Text="@FocusBadgeText" Tone="@FocusBadgeTone" />
        </div>

        <div class="aa-focus-list">
            <div>
                <strong>@Stats.PendingInvoices</strong>
                <span>invoice belum lunas</span>
            </div>
            <div>
                <strong>@Stats.OverdueInvoices</strong>
                <span>invoice overdue</span>
            </div>
            <div>
                <strong>@Stats.ProposalsSent</strong>
                <span>proposal menunggu respon</span>
            </div>
        </div>

        <p class="aa-muted aa-prose">@FocusMessage</p>

        <div class="aa-action-row">
            <a class="aa-btn aa-btn-secondary" href="/tasks">Review tasks</a>
            <a class="aa-btn aa-btn-secondary" href="/messages">Draft follow-up</a>
            <a class="aa-btn aa-btn-primary" href="/proposals">Track proposals</a>
        </div>
    </article>

    <article class="aa-panel">
        <div class="aa-panel-header aa-panel-header-split">
            <div>
                <span>Receivables</span>
                <h2>Due soon</h2>
            </div>
            <a class="aa-link" href="/invoices">View all</a>
        </div>

        <div class="aa-list">
            @if (DueInvoices.Count == 0)
            {
                <p class="aa-muted">Tidak ada invoice yang perlu ditagih.</p>
            }
            else
            {
                @foreach (var invoice in DueInvoices)
                {
                    <a class="aa-list-item aa-list-link" href="@($"/invoices/{invoice.Id}")">
                        <div>
                            <strong>@invoice.InvoiceNumber</strong>
                            <span>@(invoice.Client?.Name ?? "No client") - due @invoice.DueDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <small>@Money(invoice.Total)</small>
                    </a>
                }
            }
        </div>
    </article>

    <article class="aa-panel">
        <div class="aa-panel-header aa-panel-header-split">
            <div>
                <span>Tasks</span>
                <h2>Next actions</h2>
            </div>
            <a class="aa-link" href="/tasks">View all</a>
        </div>

        <div class="aa-list">
            @if (OpenTasks.Count == 0)
            {
                <p class="aa-muted">Tidak ada task terbuka.</p>
            }
            else
            {
                @foreach (var task in OpenTasks)
                {
                    <div class="aa-list-item">
                        <div>
                            <strong>@task.Title</strong>
                            <span>@(task.Client?.Name ?? "General") - @GetDueLabel(task.DueDate)</span>
                        </div>
                        <StatusBadge Text="@task.Priority.ToString()" Tone="@GetPriorityTone(task.Priority)" />
                    </div>
                }
            }
        </div>
    </article>

    <article class="aa-panel">
        <div class="aa-panel-header aa-panel-header-split">
            <div>
                <span>Pipeline</span>
                <h2>Recent clients</h2>
            </div>
            <a class="aa-link" href="/clients">View all</a>
        </div>

        <div class="aa-list">
            @if (RecentClients.Count == 0)
            {
                <p class="aa-muted">Belum ada client.</p>
            }
            else
            {
                @foreach (var client in RecentClients)
                {
                    <div class="aa-list-item">
                        <div>
                            <strong>@client.Name</strong>
                            <span>@(client.CompanyName ?? client.Email ?? "No detail")</span>
                        </div>
                        <StatusBadge Text="@GetClientStatusLabel(client.Status)" Tone="@GetClientStatusTone(client.Status)" />
                    </div>
                }
            }
        </div>
    </article>
</section>

@code {
    private string BusinessName { get; set; } = "AutoAdmin";
    private DashboardStats Stats { get; set; } = new();
    private List<Client> RecentClients { get; set; } = [];
    private List<TaskItem> OpenTasks { get; set; } = [];
    private List<Invoice> DueInvoices { get; set; } = [];

    private string FocusTitle => Stats.OverdueInvoices > 0
        ? "Tagih invoice overdue dulu"
        : Stats.OpenTasks > 0
            ? "Selesaikan follow-up prioritas"
            : "Workspace lagi rapi";

    private string FocusMessage => Stats.OverdueInvoices > 0
        ? "Ada invoice lewat jatuh tempo. Kirim reminder pembayaran dan update status setelah client konfirmasi."
        : Stats.OpenTasks > 0
            ? "Mulai dari task dengan prioritas tinggi dan proposal yang sudah dikirim agar pipeline tetap bergerak."
            : "Belum ada pekerjaan mendesak. Tambah client, invoice, atau proposal baru untuk menjaga alur admin tetap tercatat.";

    private string FocusBadgeText => Stats.OverdueInvoices > 0 ? "Urgent" : Stats.OpenTasks > 0 ? "Active" : "Clear";

    private string FocusBadgeTone => Stats.OverdueInvoices > 0 ? "danger" : Stats.OpenTasks > 0 ? "warning" : "success";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var business = await Db.Businesses
            .FirstOrDefaultAsync(x => x.OwnerId == userId);

        if (business is null)
        {
            business = new Business
            {
                OwnerId = userId,
                Name = "My Business",
                Industry = "UMKM / Freelancer",
                Currency = "IDR",
                InvoicePrefix = "INV"
            };

            Db.Businesses.Add(business);
            await Db.SaveChangesAsync();
        }

        BusinessName = business.Name;

        var openInvoiceStatuses = new[]
        {
            InvoiceStatus.Draft,
            InvoiceStatus.Sent,
            InvoiceStatus.Overdue
        };

        Stats.PaidRevenue = await Db.Invoices
            .Where(x => x.BusinessId == business.Id && x.Status == InvoiceStatus.Paid)
            .SumAsync(x => x.Total);

        Stats.Receivables = await Db.Invoices
            .Where(x => x.BusinessId == business.Id && openInvoiceStatuses.Contains(x.Status))
            .SumAsync(x => x.Total);

        Stats.ActiveClients = await Db.Clients
            .Where(x => x.BusinessId == business.Id && !x.IsArchived)
            .CountAsync();

        Stats.PipelineValue = await Db.Clients
            .Where(x =>
                x.BusinessId == business.Id &&
                !x.IsArchived &&
                x.Status != ClientStatus.Completed &&
                x.Status != ClientStatus.Lost)
            .SumAsync(x => x.EstimatedValue);

        Stats.PendingInvoices = await Db.Invoices
            .Where(x => x.BusinessId == business.Id && openInvoiceStatuses.Contains(x.Status))
            .CountAsync();

        var today = DateOnly.FromDateTime(DateTime.UtcNow);

        Stats.OverdueInvoices = await Db.Invoices
            .Where(x =>
                x.BusinessId == business.Id &&
                x.Status != InvoiceStatus.Paid &&
                x.Status != InvoiceStatus.Cancelled &&
                x.DueDate < today)
            .CountAsync();

        Stats.ProposalsSent = await Db.Proposals
            .Where(x => x.BusinessId == business.Id && x.Status == ProposalStatus.Sent)
            .CountAsync();

        Stats.OpenTasks = await Db.TaskItems
            .Where(x =>
                x.BusinessId == business.Id &&
                x.Status != TaskItemStatus.Done &&
                x.Status != TaskItemStatus.Cancelled)
            .CountAsync();

        RecentClients = await Db.Clients
            .AsNoTracking()
            .Where(x => x.BusinessId == business.Id && !x.IsArchived)
            .OrderByDescending(x => x.CreatedAtUtc)
            .Take(5)
            .ToListAsync();

        DueInvoices = await Db.Invoices
            .AsNoTracking()
            .Include(x => x.Client)
            .Where(x =>
                x.BusinessId == business.Id &&
                x.Status != InvoiceStatus.Paid &&
                x.Status != InvoiceStatus.Cancelled)
            .OrderBy(x => x.DueDate)
            .Take(5)
            .ToListAsync();

        OpenTasks = await Db.TaskItems
            .AsNoTracking()
            .Include(x => x.Client)
            .Where(x =>
                x.BusinessId == business.Id &&
                x.Status != TaskItemStatus.Done &&
                x.Status != TaskItemStatus.Cancelled)
            .OrderBy(x => x.DueDate)
            .ThenByDescending(x => x.Priority)
            .Take(5)
            .ToListAsync();
    }

    private static string Money(decimal value)
    {
        return $"Rp {value:N0}";
    }

    private static string GetDueLabel(DateOnly? dueDate)
    {
        return dueDate is null ? "No due date" : $"due {dueDate.Value:dd MMM yyyy}";
    }

    private static string GetPriorityTone(TaskPriority priority)
    {
        return priority switch
        {
            TaskPriority.Urgent => "danger",
            TaskPriority.High => "warning",
            TaskPriority.Medium => "info",
            _ => "neutral"
        };
    }

    private static string GetClientStatusLabel(ClientStatus status)
    {
        return status switch
        {
            ClientStatus.NewLead => "New Lead",
            ClientStatus.Contacted => "Contacted",
            ClientStatus.ProposalSent => "Proposal Sent",
            ClientStatus.Negotiation => "Negotiation",
            ClientStatus.Deal => "Deal",
            ClientStatus.Completed => "Completed",
            ClientStatus.Lost => "Lost",
            _ => status.ToString()
        };
    }

    private static string GetClientStatusTone(ClientStatus status)
    {
        return status switch
        {
            ClientStatus.NewLead => "neutral",
            ClientStatus.Contacted => "info",
            ClientStatus.ProposalSent => "purple",
            ClientStatus.Negotiation => "warning",
            ClientStatus.Deal => "success",
            ClientStatus.Completed => "success",
            ClientStatus.Lost => "danger",
            _ => "neutral"
        };
    }

    private sealed class DashboardStats
    {
        public decimal PaidRevenue { get; set; }
        public decimal Receivables { get; set; }
        public decimal PipelineValue { get; set; }
        public int ActiveClients { get; set; }
        public int PendingInvoices { get; set; }
        public int OverdueInvoices { get; set; }
        public int ProposalsSent { get; set; }
        public int OpenTasks { get; set; }
    }
}
