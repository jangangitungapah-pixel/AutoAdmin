@page "/"
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>AutoAdmin — Business Operating System</PageTitle>

<main class="aa-auth-shell">
    <section class="aa-auth-card aa-home-card">
        <div class="aa-brand-row">
            <div class="aa-logo">A</div>
            <div>
                <strong>AutoAdmin</strong>
                <span>AI Business Operating System</span>
            </div>
        </div>

        <div class="aa-home-content">
            <p class="aa-kicker">Untuk UMKM & Freelancer</p>

            <h1>Admin bisnis yang rapi, cepat, dan siap dipakai beneran.</h1>

            <p>
                Kelola client, invoice, proposal, follow-up, task, dan insight bisnis dalam satu workspace.
                Ini bukan demo portfolio — ini fondasi aplikasi AutoAdmin.
            </p>

            <div class="aa-auth-actions">
                <a class="aa-btn aa-btn-primary" href="/register">Create Account</a>
                <a class="aa-btn aa-btn-secondary" href="/login">Login</a>
            </div>

            <div class="aa-demo-box">
                <span>Demo account</span>
                <strong>demo@autoadmin.local</strong>
                <small>Password: Demo123!</small>
            </div>
        </div>
    </section>
</main>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
    }
}